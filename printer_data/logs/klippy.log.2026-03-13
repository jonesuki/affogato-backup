[gcode_macro G32]
gcode = 
	SAVE_GCODE_STATE NAME=STATE_G32
	G90
	G28
	
	QUAD_GANTRY_LEVEL
	G28
	
	RESTORE_GCODE_STATE NAME=STATE_G32

[gcode_macro PRINT_START]
gcode = 
	
	{% set target_bed = params.BED|int %}
	{% set target_hotend = params.HOTEND|int %}
	{% set target_chamber = params.CHAMBER|default("40")|int %}
	{% set target_chamber_wait = [target_chamber, target_chamber_minimal]|select(">", 0)|min|default(0) %}
	{% set x_wait = printer.toolhead.axis_maximum.x|float / 2 %}
	{% set y_wait = printer.toolhead.axis_maximum.y|float / 2 %}
	
	CLEAR_PAUSE
	
	STATUS_HOMING
	G28
	G90
	
	BED_MESH_CLEAR
	
	
	SET_DISPLAY_TEXT MSG="Set Bed to {target_bed}C"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M190 S{target_bed}
	
	
	{% if params.BED|int > 90 %}
	SET_DISPLAY_TEXT MSG="Heatsoak chamber to {target_chamber_wait}c"
	TEMPERATURE_WAIT SENSOR="temperature_sensor chamber" MINIMUM={target_chamber_wait}
	
	{% else %}
	SET_DISPLAY_TEXT MSG="Soak for 5 min"
	G4 P300000
	{% endif %}
	
	
	SET_DISPLAY_TEXT MSG="Preheat hotend to 150c"
	M109 S150
	
	SET_DISPLAY_TEXT MSG="Cleaning nozzle"
	CLEAN_NOZZLE
	
	SET_DISPLAY_TEXT MSG="Quad Gantry Level"
	STATUS_LEVELING
	QUAD_GANTRY_LEVEL
	
	SET_DISPLAY_TEXT MSG="Cartographer touch home"
	CARTOGRAPHER_TOUCH_HOME
	
	SET_DISPLAY_TEXT MSG="Bed mesh"
	STATUS_MESHING
	BED_MESH_CALIBRATE ADAPTIVE=1
	
	SET_DISPLAY_TEXT MSG="Set hotend to terget temp of {target_hotend}"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M109 S{target_hotend}
	
	SET_DISPLAY_TEXT MSG="Load skew profile"
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural
	
	SET_DIEPLAY_TEXT MSG="Start printing"
	STATUS_PRINTING

[gcode_macro PRINT_END]
gcode = 
	SET_SKEW CLEAR=1
	
	
	{% set th = printer.toolhead %}
	{% set x_safe = th.position.x + 20 * (1 if th.axis_maximum.x - th.position.x > 20 else -1) %}
	{% set y_safe = th.position.y + 20 * (1 if th.axis_maximum.y - th.position.y > 20 else -1) %}
	{% set z_safe = [th.position.z + 2, th.axis_maximum.z]|min %}
	
	SAVE_GCODE_STATE NAME=STATE_PRINT_END
	
	M400
	G92 E0
	G1 E-6.0 F1800
	
	TURN_OFF_HEATERS
	
	G90
	G0 X{x_safe} Y{y_safe} Z{z_safe} F20000
	G0 X{th.axis_maximum.x//2} Y{th.axis_maximum.y - 2} F3600
	
	M107
	
	BED_MESH_CLEAR
	RESTORE_GCODE_STATE NAME=STATE_PRINT_END

