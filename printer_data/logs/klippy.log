[delayed_gcode CHECK_ALL_FANS]
initial_duration = 1
gcode = 
	HOTEND_FAN_CHECK
	UPDATE_DELAYED_GCODE ID=CHECK_ALL_FANS DURATION=3

[gcode_macro HOTEND_FAN_CHECK]
variable_he_stop_count = 0
gcode = 
	{% set min_rpm = 8000|float %}
	{% set max_consecutive_stops = 3 %}
	{% set rpm = printer['heater_fan Hotend_Fan'].rpm|float %}
	{% set he_target = printer[printer.toolhead.extruder].target|float %}
	{% set he_temp = printer[printer.toolhead.extruder].temperature|float %}
	{% set fan_on_temp = printer.configfile.settings['heater_fan hotend_fan'].heater_temp|float %}
	{% set he_stop_count = printer["gcode_macro HOTEND_FAN_CHECK"].he_stop_count|int %}
	
	{% if (he_target >= fan_on_temp) and (rpm < min_rpm) and (he_temp >= fan_on_temp) %}
	SET_GCODE_VARIABLE MACRO=HOTEND_FAN_CHECK VARIABLE=he_stop_count VALUE={he_stop_count + 1}
	M118 WARNING: Fan stoppage detected ({he_stop_count+1}/{max_consecutive_stops}).
	M400
	{% if printer["gcode_macro HOTEND_FAN_CHECK"].he_stop_count|int >= max_consecutive_stops-1 %}
	FAN_STOPPAGE_ROUTINE
	{% endif %}
	{% else %}
	SET_GCODE_VARIABLE MACRO=HOTEND_FAN_CHECK VARIABLE=he_stop_count VALUE=0
	{% endif %}

[gcode_macro FAN_STOPPAGE_ROUTINE]
gcode = 
	
	{% if printer['pause_resume'].is_paused|int == 0 %}
	M117 !!FAN STOPPAGE!!
	M118 FAN STOPPAGE DETECTED. PAUSING...
	PAUSE
	
	
	
	
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET=0
	{% endif %}

[gcode_macro _SENSOR_VARIABLES]
variable_filament_load_temp = 235
variable_filament_unload_temp = 185
variable_filament_load_min_temp = 190
variable_nozzle_purge_length = 100
variable_nozzle_purge_speed = 450
variable_unload_distance = 70
variable_disable_autoload = False
variable_disable_autounload = False
variable_disable_runnout = False
variable_disable_autochange = True
variable_enable_beep = True
variable_park_position_x = 150
variable_park_position_y = 0
variable_park_lift_z = 75
variable_park_retraction = 1
gcode = 

[gcode_button filament_sense]
pin = orbitoolO2S:PA8
press_gcode = 
	runnout_init
release_gcode = 
	filament_load_init

[gcode_button filament_unload]
pin = !orbitoolO2S:PA9
release_gcode = 
	filament_unload_init
press_gcode = 

[force_move]
enable_force_move = True

[gcode_macro runnout_init]
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if (printer.print_stats.state == "printing") %}
	{% if(sensor.disable_runnout|lower == 'false') %}
	filament_change_state1
	{% else %}
	M118 O2S: Filament runout is disabled in the sensor config file!
	{% endif %}
	{% endif %}
	UPDATE_DELAYED_GCODE ID=clear_loadbusy DURATION=2
	UPDATE_DELAYED_GCODE ID=clear_unloadbusy DURATION=2
	SET_GCODE_VARIABLE MACRO=filament_unload VARIABLE=filamentpresent VALUE=0

[gcode_macro filament_change_state1]
variable_changebusy = 0
variable_temp_target = 0
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if changebusy == 0 %}
	M118 O2S: Printer paused due to filament runout!
	PAUSE
	{% if (sensor.disable_autochange|lower == 'false') %}
	SET_GCODE_VARIABLE MACRO=filament_change_state1 VARIABLE=changebusy VALUE=1
	filament_change_state2
	{% endif %}
	{% endif %}

[gcode_macro filament_change_state2]
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	SET_GCODE_VARIABLE MACRO=filament_load VARIABLE=loadbusy VALUE=1
	{% if (sensor.enable_beep|lower == 'true') %}
	BEEP
	{% endif %}
	M118 O2S: Unloading filament...
	M83
	G92 E0
	
	{% if (printer.extruder.can_extrude|lower != 'true')%}
	
	M118 O2S: Hotend heating!
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={sensor.filament_unload_temp}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={sensor.filament_unload_temp}
	{% endif %}
	{% if(printer.extruder.target == 0) %}
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={sensor.filament_unload_temp}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={sensor.filament_unload_temp}
	{% endif %}
	G0 E-5 F3600
	G4 P2000
	G0 E5 F3600
	G0 E-5 F3600
	G0 E-{sensor.unload_distance} F300
	M400
	M118 O2S: Load new filament! Wait until is loaded, then resume printing.
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET=0
	UPDATE_DELAYED_GCODE ID=clear_loadbusy DURATION=2.5

[gcode_macro filament_load_init]
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if (printer.print_stats.state != "printing") %}
	{% if(sensor.disable_autoload|lower == 'false') %}
	filament_load
	{% else %}
	M118 O2S: Filament auto-load is disabled in the sensor config file!
	{% endif %}
	{% else %}
	M118 O2S: Printing! Can't load filament right now!
	{% endif %}
	SET_GCODE_VARIABLE MACRO=filament_unload VARIABLE=filamentpresent VALUE=1
	UPDATE_DELAYED_GCODE ID=clear_changebusy DURATION=2

[gcode_macro filament_load]
variable_loadbusy = 0
variable_user_temp = 0
variable_load_temp = 0
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if loadbusy == 0 %}
	SET_GCODE_VARIABLE MACRO=filament_load VARIABLE=loadbusy VALUE=1
	SET_GCODE_VARIABLE MACRO=filament_unload VARIABLE=unloadbusy VALUE=1
	{% set USER_TEMP = printer.extruder.target %}
	{% set LOAD_TEMP = 0 %}
	{% if (printer.extruder.can_extrude|lower != 'true') or (printer.extruder.target < sensor.filament_load_min_temp) %}
	
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={sensor.filament_load_temp}
	{% set LOAD_TEMP = sensor.filament_load_temp %}
	M118 O2S: Hotend heating!
	{% endif %}
	{% if (sensor.enable_beep|lower == 'true') %}
	BEEP
	{% endif %}
	M118 O2S: Filament loading!
	M82
	G92 E0
	G4 P1500
	FORCE_MOVE STEPPER=extruder DISTANCE=15 VELOCITY=10 ACCEL=1000
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={LOAD_TEMP}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={USER_TEMP}
	G1 E{sensor.nozzle_purge_length} F{sensor.nozzle_purge_speed}
	M400
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={USER_TEMP}
	M118 O2S: Filament load complete!
	UPDATE_DELAYED_GCODE ID=clear_unloadbusy DURATION=2
	{% else %}
	M118 O2S: Filament already loaded!
	{% endif %}

[gcode_macro filament_unload_init]
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if (printer.print_stats.state != "printing") %}
	{% if(sensor.disable_autounload|lower == 'false') %}
	filament_unload
	M118 O2S: filament unload called
	{% else %}
	M118 O2S: Filament auto-unload is disabled in the sensor config file!
	{% endif %}
	{% else %}
	M118 O2S: Printing! Can't unload filament right now!
	{% endif %}

[gcode_macro filament_unload]
variable_unloadbusy = 0
variable_filamentpresent = 0
gcode = 
	{% set sensor = printer['gcode_macro _SENSOR_VARIABLES'] %}
	{% if unloadbusy == 0 %}
	SET_GCODE_VARIABLE MACRO=filament_unload VARIABLE=unloadbusy VALUE=1
	SET_GCODE_VARIABLE MACRO=filament_load VARIABLE=loadbusy VALUE=1
	{% if (sensor.enable_beep|lower == 'true') %}
	BEEP
	{% endif %}
	M118 O2S: Filament unloading!
	M83
	G92 E0
	
	{% if (printer.extruder.can_extrude|lower != 'true')%}
	
	M118 O2S: Hotend heating!
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={sensor.filament_unload_temp}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={sensor.filament_unload_temp}
	{% endif %}
	{% if(printer.extruder.target == 0) %}
	SET_HEATER_TEMPERATURE HEATER=extruder TARGET={sensor.filament_unload_temp}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={sensor.filament_unload_temp}
	{% endif %}
	G0 E10 F500
	G0 E-5 F3600
	G4 P2000
	G0 E6 F3600
	G0 E-10 F3600
	G0 E-{sensor.unload_distance} F300
	M104 S0 T0
	M400
	M118 O2S: Filament unload complete!
	
	{% if (sensor.enable_beep|lower == 'true') %}
	BEEP
	{% endif %}
	{% else %}
	M118 O2S: Nothing to unload!
	{% endif %}

[delayed_gcode clear_unloadbusy]
gcode = 
	SET_GCODE_VARIABLE MACRO=filament_unload VARIABLE=unloadbusy VALUE=0

[delayed_gcode clear_changebusy]
gcode = 
	SET_GCODE_VARIABLE MACRO=filament_change_state1 VARIABLE=changebusy VALUE=0

[delayed_gcode set_loadbusy]
gcode = 
	SET_GCODE_VARIABLE MACRO=filament_load VARIABLE=loadbusy VALUE=1

[delayed_gcode clear_loadbusy]
gcode = 
	SET_GCODE_VARIABLE MACRO=filament_load VARIABLE=loadbusy VALUE=0

