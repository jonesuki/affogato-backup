sensor_mcu = cartographer
min_temp = 5
max_temp = 105

[firmware_retraction]
retract_length = 1.2
retract_speed = 120
unretract_extra_length = 0.0
unretract_speed = 120

[adxl345 o2sADXL]
cs_pin = orbitoolO2S:PA4
spi_bus = spi1
axes_map = y, z, x
spi_speed = 5000000

[adxl345 cartoADXL]
