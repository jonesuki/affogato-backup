[cartographer touch]
samples = 3
max_samples = 20
max_noisy_samples = 2
unsafe_max_touch_temperature = 150

[bed_mesh]
zero_reference_position = 150, 150
speed = 300
horizontal_move_z = 3
mesh_min = 20, 30
mesh_max = 280, 270
probe_count = 20, 20
adaptive_margin = 10
mesh_pps = 0,0

[fan]
pin = !orbitoolO2S:PA10
enable_pin = orbitoolO2S:PB14
off_below = 0.2
tachometer_pin = orbitoolO2S:PA14
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
shutdown_speed = 0.0
cycle_time = 0.0001
kick_start_time = 0.2
hardware_pwm = False

[heater_fan Hotend_Fan]
pin = !orbitoolO2S:PB15
tachometer_pin = orbitoolO2S:PB12
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
heater = extruder
cycle_time = 0.0001
heater_temp = 100
fan_speed = 1.0
hardware_pwm = false
shutdown_speed = 0.0
max_power = 0.5

[controller_fan Electronics_Fan]
pin = PD12
max_power = 0.25
kick_start_time = 0.5
idle_timeout = 30
heater = heater_bed
stepper = stepper_x,stepper_y,stepper_z,stepper_z1,stepper_z2,stepper_z3

[fan_generic Exhaust_Fan]
pin = PD13
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[output_pin chamber_light]
pin = PB10
pwm = true
shutdown_value = 0
value = 0
cycle_time = 0.01

[output_pin T0_RUN_LED]
pin = orbitoolO2S:PB13
value = 1
shutdown_value = 0

[idle_timeout]
timeout = 7200

[safe_z_home]
home_xy_position = 150,150
speed = 100
z_hop = 10

[quad_gantry_level]
gantry_corners = 
	-60,-10
	360,370
points = 
	50,25
	50,225
	250,225
	250,25
speed = 150
horizontal_move_z = 5
retries = 5
retry_tolerance = 0.0075
max_adjust = 10

[temperature_sensor Raspberry_Pi]
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp

[temperature_sensor Octopus_Pro]
sensor_type = temperature_mcu
sensor_mcu = mcu

[temperature_sensor chamber]
sensor_type = ATC Semitec 104NT-4-R025H42G
sensor_pin = PF4

[temperature_sensor Hotend_heatsink]
sensor_type = NTC 100K MGB18-104F39050L32
sensor_pin = PF5

[temperature_sensor toolboard]
sensor_type = temperature_mcu
sensor_mcu = orbitoolO2S

[temperature_sensor cartographer]
sensor_type = temperature_mcu
sensor_mcu = cartographer
min_temp = 5
max_temp = 105

[firmware_retraction]
retract_length = 1.2
retract_speed = 120
unretract_extra_length = 0.0
unretract_speed = 120

[adxl345 o2sADXL]
cs_pin = orbitoolO2S:PA4
spi_bus = spi1
axes_map = y, z, x
spi_speed = 5000000

[adxl345 cartoADXL]
cs_pin = cartographer:PA0
spi_bus = spi1

[resonance_tester]
accel_chip = adxl345 o2sADXL
probe_points = 
	150,150,20

[input_shaper]
shaper_freq_x = 82.0
shaper_type_x = 2hump_ei
shaper_freq_y = 40.2
shaper_type_y = mzv

[skew_correction]

[exclude_object]

[axis_twist_compensation]

[gcode_macro G32]
gcode = 
	SAVE_GCODE_STATE NAME=STATE_G32
	G90
	G28
	
	QUAD_GANTRY_LEVEL
	G28
	
	RESTORE_GCODE_STATE NAME=STATE_G32

[gcode_macro PRINT_START]
gcode = 
	
	{% set target_bed = params.BED|int %}
	{% set target_hotend = params.HOTEND|int %}
	{% set target_chamber = params.CHAMBER|default("40")|int %}
	{% set target_chamber_wait = [target_chamber, target_chamber_minimal]|select(">", 0)|min|default(0) %}
	{% set x_wait = printer.toolhead.axis_maximum.x|float / 2 %}
	{% set y_wait = printer.toolhead.axis_maximum.y|float / 2 %}
	
	CLEAR_PAUSE
	
	STATUS_HOMING
	G28
	G90
	
	BED_MESH_CLEAR
	
	
	SET_DISPLAY_TEXT MSG="Set Bed to {target_bed}C"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M190 S{target_bed}
	
	
	{% if params.BED|int > 90 %}
	SET_DISPLAY_TEXT MSG="Heatsoak chamber to {target_chamber_wait}c"
	TEMPERATURE_WAIT SENSOR="temperature_sensor chamber" MINIMUM={target_chamber_wait}
	
	{% else %}
	SET_DISPLAY_TEXT MSG="Soak for 5 min"
	G4 P300000
	{% endif %}
	
	
	SET_DISPLAY_TEXT MSG="Preheat hotend to 150c"
	M109 S150
	
	SET_DISPLAY_TEXT MSG="Cleaning nozzle"
	CLEAN_NOZZLE
	
	SET_DISPLAY_TEXT MSG="Quad Gantry Level"
	STATUS_LEVELING
	QUAD_GANTRY_LEVEL
	
	SET_DISPLAY_TEXT MSG="Cartographer touch home"
	CARTOGRAPHER_TOUCH_HOME
	
	SET_DISPLAY_TEXT MSG="Bed mesh"
	STATUS_MESHING
	BED_MESH_CALIBRATE ADAPTIVE=1
	
	SET_DISPLAY_TEXT MSG="Set hotend to terget temp of {target_hotend}"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M109 S{target_hotend}
	
	SET_DISPLAY_TEXT MSG="Load skew profile"
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural
	
	SET_DIEPLAY_TEXT MSG="Start printing"
	STATUS_PRINTING

[gcode_macro PRINT_END]
gcode = 
	SET_SKEW CLEAR=1
	
	
	{% set th = printer.toolhead %}
	{% set x_safe = th.position.x + 20 * (1 if th.axis_maximum.x - th.position.x > 20 else -1) %}
	{% set y_safe = th.position.y + 20 * (1 if th.axis_maximum.y - th.position.y > 20 else -1) %}
	{% set z_safe = [th.position.z + 2, th.axis_maximum.z]|min %}
	
	SAVE_GCODE_STATE NAME=STATE_PRINT_END
	
	M400
	G92 E0
	G1 E-6.0 F1800
	
	TURN_OFF_HEATERS
	
	G90
	G0 X{x_safe} Y{y_safe} Z{z_safe} F20000
	G0 X{th.axis_maximum.x//2} Y{th.axis_maximum.y - 2} F3600
	
	M107
	
	BED_MESH_CLEAR
	RESTORE_GCODE_STATE NAME=STATE_PRINT_END

[bed_mesh default]
version = 1
points = 
	-0.032500, -0.023750, -0.040000
