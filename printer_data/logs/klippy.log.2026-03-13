value = 1
shutdown_value = 0

[idle_timeout]
timeout = 7200

[safe_z_home]
home_xy_position = 150,150
speed = 100
z_hop = 10

[quad_gantry_level]
gantry_corners = 
	-60,-10
	360,370
points = 
	50,25
	50,225
	250,225
	250,25
speed = 150
horizontal_move_z = 5
retries = 5
retry_tolerance = 0.0075
max_adjust = 10

[temperature_sensor Raspberry_Pi]
