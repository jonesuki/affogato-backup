[tmc2240 extruder]
uart_pin = orbitoolO2S:PC13
interpolate = false
run_current = 0.85
rref = 12000
stealthchop_threshold = 0

[heater_bed]
heater_pin = PA3
sensor_type = Generic 3950
sensor_pin = PF3
max_power = 1.0
min_temp = 0
max_temp = 120
control = pid
pid_kp = 63.364
pid_ki = 2.235
pid_kd = 449.091

[fan]
pin = !orbitoolO2S:PA10
enable_pin = orbitoolO2S:PB14
off_below = 0.2
tachometer_pin = orbitoolO2S:PA14
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
shutdown_speed = 0.0
cycle_time = 0.0001
kick_start_time = 0.2
hardware_pwm = False

[heater_fan Hotend_Fan]
pin = !orbitoolO2S:PB15
tachometer_pin = orbitoolO2S:PB12
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
heater = extruder
cycle_time = 0.0001
heater_temp = 75
fan_speed = 1.0
hardware_pwm = false
shutdown_speed = 0.0
max_power = 0.5

[controller_fan Electronics_Fan]
pin = PD12
max_power = 0.25
kick_start_time = 0.5
idle_timeout = 30
heater = heater_bed
stepper = stepper_x,stepper_y,stepper_z,stepper_z1,stepper_z2,stepper_z3

[fan_generic Exhaust_Fan]
pin = PD13
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[output_pin chamber_light]
pin = PB10
pwm = true
shutdown_value = 0
value = 0
cycle_time = 0.01

[idle_timeout]
timeout = 7200

[safe_z_home]
home_xy_position = 150,150
speed = 100
z_hop = 10

[quad_gantry_level]
gantry_corners = 
	-60,-10
	360,370
points = 
	50,25
	50,225
	250,225
	250,25
speed = 100
horizontal_move_z = 10
retries = 5
retry_tolerance = 0.0075
max_adjust = 10

[cartographer]
mcu = cartographer
x_offset = 2.8
y_offset = 27
verbose = no

[bed_mesh]
zero_reference_position = 150, 150
speed = 300
horizontal_move_z = 3
mesh_min = 40, 40
mesh_max = 260,260
probe_count = 20, 20
adaptive_margin = 10
mesh_pps = 0,0

[temperature_sensor Raspberry_Pi]
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp

[temperature_sensor Octopus_Pro]
sensor_type = temperature_mcu
sensor_mcu = mcu

[temperature_sensor Chamber]
sensor_type = ATC Semitec 104NT-4-R025H42G
sensor_pin = PF4

[temperature_sensor toolboard]
sensor_type = temperature_mcu
sensor_mcu = orbitoolO2S

[output_pin T0_RUN_LED]
pin = orbitoolO2S:PB13
value = 1
shutdown_value = 0

[temperature_sensor cartographer]
sensor_type = temperature_mcu
sensor_mcu = cartographer
min_temp = 5
max_temp = 105

[firmware_retraction]
retract_length = 1.2
retract_speed = 120
unretract_extra_length = 0.0
unretract_speed = 120

[adxl345 Tool1]
cs_pin = orbitoolO2S:PA4
spi_bus = spi1
axes_map = y, z, x
spi_speed = 5000000

[resonance_tester]
accel_chip = adxl345
probe_points = 
	150,150,20

[input_shaper]
shaper_freq_x = 82.0
shaper_type_x = 2hump_ei
shaper_freq_y = 40.2
shaper_type_y = mzv

[skew_correction]

[exclude_object]

[gcode_macro G32]
gcode = 
	SAVE_GCODE_STATE NAME=STATE_G32
	G90
	G28
	
	QUAD_GANTRY_LEVEL
	G28
	
	
	RESTORE_GCODE_STATE NAME=STATE_G32

[gcode_macro PRINT_START]
gcode = 
	
	
	{% set bedtemp = params.BED|int %}
	{% set hotendtemp = params.HOTEND|int %}
	
	
	G28
	
	M190 S{bedtemp}
	
	
	M109 S175
	clean_nozzle
	
	{% if hotendtemp*0.75 <= 150 %}
	M109 S{(hotendtemp*0.75)|round(0,'ceil')|int}
	{% else %}
	M109 S150
	{% endif %}
	
	BED_MESH_CLEAR
	G32
	BED_MESH_CALIBRATE
	G28 Z
	
	G90
	
	
	
	
	Smart_Park
	
	M109 S{hotendtemp}
	
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural

[gcode_macro PRINT_END]
gcode = 
	SET_SKEW CLEAR=1
	
	
	{% set th = printer.toolhead %}
	{% set x_safe = th.position.x + 20 * (1 if th.axis_maximum.x - th.position.x > 20 else -1) %}
	{% set y_safe = th.position.y + 20 * (1 if th.axis_maximum.y - th.position.y > 20 else -1) %}
	{% set z_safe = [th.position.z + 2, th.axis_maximum.z]|min %}
	
	SAVE_GCODE_STATE NAME=STATE_PRINT_END
	
	M400
	G92 E0
	G1 E-6.0 F1800
	
	TURN_OFF_HEATERS
	
	G90
	G0 X{x_safe} Y{y_safe} Z{z_safe} F20000
	G0 X{th.axis_maximum.x//2} Y{th.axis_maximum.y - 2} F3600
	
	M107
	
	BED_MESH_CLEAR
	RESTORE_GCODE_STATE NAME=STATE_PRINT_END

[bed_mesh default]
version = 1
points = 
	-0.032500, -0.023750, -0.040000
	-0.026250, -0.013750, -0.027500
	-0.006250, 0.003750, 0.001250
x_count = 3
y_count = 3
mesh_x_pps = 2
mesh_y_pps = 2
algo = lagrange
tension = 0.2
min_x = 96.97999999999999
max_x = 202.32
min_y = 96.97
max_y = 202.42999999999998

[probe]
z_offset = -0.930

[skew_correction Fillamentum_Extrafill_ASA_Natural]
xy_skew = 0.0024960884031216104
xz_skew = 0.0002050607695965943
yz_skew = -0.00013435074108080882
