tachometer_pin = orbitoolO2S:PB12
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
heater = extruder
cycle_time = 0.0001
heater_temp = 100
fan_speed = 1.0
hardware_pwm = false
shutdown_speed = 0.0
max_power = 0.5

[controller_fan Electronics_Fan]
pin = PD12
max_power = 1.0
shutdown_speed = 0.0
cycle_time = 0.010
kick_start_time = 0.5
off_below = 0.0
fan_speed = 0.4
idle_timeout = 30
idle_speed = 0.25
heater = heater_bed
stepper = stepper_x,stepper_y,stepper_z,stepper_z1,stepper_z2,stepper_z3, extruder

[temperature_fan Host_MCU_Fan]
pin = PD12
max_power = 1.0
shutdown_speed = 0.0
cycle_time = 0.010
kick_start_time = 0.5
