[gcode_macro QUAD_GANTRY_LEVEL]
rename_existing = _QUAD_GANTRY_LEVEL
gcode = 
	
	{% if printer.quad_gantry_level.applied == False %}
	_QUAD_GANTRY_LEVEL RETRY_TOLERANCE=1.0
	{% endif %}
	
	
	_FINE_QUAD_GANTRY_LEVEL

[gcode_macro _FINE_QUAD_GANTRY_LEVEL]
gcode = 
	{% if printer.quad_gantry_level.applied == True %}
	
	_QUAD_GANTRY_LEVEL HORIZONTAL_MOVE_Z=2.0
	{% else %}
	
	{action_respond_info("Fine QGL called without calling course QGL first!")}
	_QUAD_GANTRY_LEVEL
	{% endif %}

[gcode_macro G32]
gcode = 
	SAVE_GCODE_STATE NAME=STATE_G32
	G90
	G28
	
	QUAD_GANTRY_LEVEL
	G28
	
	RESTORE_GCODE_STATE NAME=STATE_G32

[gcode_macro PRINT_START]
gcode = 
	
	
	{% set bedtemp = params.BED|int %}
	{% set hotendtemp = params.HOTEND|int %}
	
	
	G28
	
	M190 S{bedtemp}
	
	
	{% if hotendtemp*0.75 <= 150 %}
	M109 S{(hotendtemp*0.75)|round(0,'ceil')|int}
	{% else %}
	M109 S150
	{% endif %}
	
	clean_nozzle
	
	BED_MESH_CLEAR
	G32
	BED_MESH_CALIBRATE
	
	
	CARTOGRAPHER_TOUCH_HOME
	
	G90
	
	Smart_Park
	
	M109 S{hotendtemp}
	
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural

[gcode_macro PRINT_END]
gcode = 
	SET_SKEW CLEAR=1
	
	
	{% set th = printer.toolhead %}
	{% set x_safe = th.position.x + 20 * (1 if th.axis_maximum.x - th.position.x > 20 else -1) %}
	{% set y_safe = th.position.y + 20 * (1 if th.axis_maximum.y - th.position.y > 20 else -1) %}
	{% set z_safe = [th.position.z + 2, th.axis_maximum.z]|min %}
	
	SAVE_GCODE_STATE NAME=STATE_PRINT_END
	
	M400
	G92 E0
	G1 E-6.0 F1800
	
	TURN_OFF_HEATERS
	
	G90
	G0 X{x_safe} Y{y_safe} Z{z_safe} F20000
	G0 X{th.axis_maximum.x//2} Y{th.axis_maximum.y - 2} F3600
	
	M107
	
	BED_MESH_CLEAR
	RESTORE_GCODE_STATE NAME=STATE_PRINT_END

