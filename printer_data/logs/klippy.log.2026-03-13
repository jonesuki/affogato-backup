probe_count = 20, 20
adaptive_margin = 10
mesh_pps = 0,0

[fan]
pin = !orbitoolO2S:PA10
enable_pin = orbitoolO2S:PB14
off_below = 0.2
tachometer_pin = orbitoolO2S:PA14
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
shutdown_speed = 0.0
cycle_time = 0.0001
kick_start_time = 0.2
hardware_pwm = False

[heater_fan Hotend_Fan]
pin = !orbitoolO2S:PB15
tachometer_pin = orbitoolO2S:PB12
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
heater = extruder
cycle_time = 0.0001
heater_temp = 100
fan_speed = 1.0
hardware_pwm = false
shutdown_speed = 0.0
max_power = 0.5

[controller_fan Electronics_Fan]
pin = PD12
max_power = 0.25
kick_start_time = 0.5
idle_timeout = 30
heater = heater_bed
stepper = stepper_x,stepper_y,stepper_z,stepper_z1,stepper_z2,stepper_z3

[fan_generic Exhaust_Fan]
pin = PD13
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[output_pin chamber_light]
pin = PB10
pwm = true
shutdown_value = 0
value = 0
cycle_time = 0.01

[output_pin T0_RUN_LED]
pin = orbitoolO2S:PB13
value = 1
shutdown_value = 0

[idle_timeout]
timeout = 7200

[safe_z_home]
home_xy_position = 150,150
speed = 100
z_hop = 10

[quad_gantry_level]
gantry_corners = 
	-60,-10
	360,370
points = 
	50,25
	50,225
	250,225
	250,25
speed = 150
horizontal_move_z = 5
retries = 5
retry_tolerance = 0.0075
max_adjust = 10

[temperature_sensor Raspberry_Pi]
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp

[temperature_sensor Octopus_Pro]
sensor_type = temperature_mcu
sensor_mcu = mcu

[temperature_sensor chamber]
