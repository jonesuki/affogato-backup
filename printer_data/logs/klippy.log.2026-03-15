[display_template _vheater_temperature]
param_heater_name = "extruder"
text = 
	{% if param_heater_name in printer %}
	{% set heater = printer[param_heater_name] %}
	
	{% if param_heater_name == "heater_bed" %}
	{% if heater.target %}
	{% set frame = (printer.toolhead.estimated_print_time|int % 2) + 1 %}
	~bed_heat{frame}~
	{% else %}
	~bed~
	{% endif %}
	{% else %}
	~extruder~
	{% endif %}
	
	{ "%3.0f" % (heater.temperature,) }
	
	{% if heater.target and (heater.temperature - heater.target)|abs > 2 %}
	~right_arrow~
	{ "%0.0f" % (heater.target,) }
	{% endif %}
	~degrees~
	{% endif %}

[display_data __voron_display extruder]
position = 0, 0
text = { render("_vheater_temperature", param_heater_name="extruder") }

[display_data __voron_display fan]
position = 0, 10
text = 
	{% if 'fan' in printer %}
	{% set speed = printer.fan.speed %}
	{% if speed %}
	{% set frame = (printer.toolhead.estimated_print_time|int % 2) + 1 %}
	~fan{frame}~
	{% else %}
	~fan1~
	{% endif %}
	{ "{:>4.0%}".format(speed) }
	{% endif %}

[display_data __voron_display bed]
position = 1, 0
text = { render("_vheater_temperature", param_heater_name="heater_bed") }

[display_data __voron_display progress_text]
position = 1, 10
text = 
	{% set progress = printer.display_status.progress %}
	{ "{:^6.0%}".format(progress) }

[display_data __voron_display progress_text2]
position = 1, 10
text = 
	{% set progress = printer.display_status.progress %}
	{ draw_progress_bar(1, 10, 6, progress) }

[display_data __voron_display printing_time]
position = 2, 10
text = 
	{% set ptime = printer.idle_timeout.printing_time %}
	{ "%02d:%02d" % (ptime // (60 * 60), (ptime // 60) % 60) }

[display_data __voron_display chamber]
position = 2, 0
text = 
	{% set chamber = printer['temperature_sensor chamber'] %}
	~chamber~
	{ "%3.0f" % (chamber.temperature,) }
	~degrees~

[display_data __voron_display print_status]
position = 3, 0
text = 
	{% if printer.display_status.message %}
	{ printer.display_status.message }
	{% elif printer.idle_timeout.printing_time %}
	{% set pos = printer.toolhead.position %}
	{ "X%-4.0fY%-4.0fZ%-5.2f" % (pos.x, pos.y, pos.z) }
	{% else %}
	{ "V2.5772 " }
	~voron~
	{% endif %}

[printer]
kinematics = corexy
max_velocity = 300
max_accel = 6500
max_z_velocity = 15
max_z_accel = 350
square_corner_velocity = 5.0

[mcu]
serial = /dev/serial/by-id/usb-Klipper_stm32f429xx_25004C000F50304738313820-if00
restart_method = command

[mcu orbitoolO2S]
serial = /dev/serial/by-id/usb-Klipper_stm32f072xb_Orbitool_O2S-if00
restart_method = command

[mcu cartographer]
serial = /dev/serial/by-id/usb-Cartographer_stm32g431xx_3E0055000650303448383620-if00
restart_method = command

[stepper_x]
step_pin = PF13
dir_pin = PF12
enable_pin = !PF14
rotation_distance = 40
microsteps = 64
full_steps_per_rotation = 400
endstop_pin = orbitoolO2S:PA2
position_min = 0
position_endstop = 300
position_max = 300
homing_speed = 50
homing_retract_dist = 5
homing_positive_dir = true

[tmc2209 stepper_x]
uart_pin = PC4
interpolate = false
run_current = 1.0
sense_resistor = 0.110
stealthchop_threshold = 0

[stepper_y]
step_pin = PG0
dir_pin = PG1
enable_pin = !PF15
rotation_distance = 40
microsteps = 64
full_steps_per_rotation = 400
endstop_pin = PG9
position_min = 0
position_endstop = 300
position_max = 300
homing_speed = 50
homing_retract_dist = 5
homing_positive_dir = true

[tmc2209 stepper_y]
uart_pin = PD11
interpolate = false
run_current = 1.0
sense_resistor = 0.110
stealthchop_threshold = 0

[stepper_z]
step_pin = PF11
dir_pin = PG3
enable_pin = !PG5
rotation_distance = 40
gear_ratio = 80:16
microsteps = 32
endstop_pin = probe:z_virtual_endstop
homing_retract_dist = 0
position_max = 240
position_min = -5
homing_speed = 8
second_homing_speed = 3

[tmc2209 stepper_z]
uart_pin = PC6
interpolate = false
run_current = 0.8
sense_resistor = 0.110
stealthchop_threshold = 999999

[stepper_z1]
step_pin = PG4
dir_pin = !PC1
enable_pin = !PA0
rotation_distance = 40
gear_ratio = 80:16
microsteps = 32

[tmc2209 stepper_z1]
uart_pin = PC7
interpolate = false
run_current = 0.8
sense_resistor = 0.110
stealthchop_threshold = 999999

[stepper_z2]
step_pin = PF9
dir_pin = PF10
enable_pin = !PG2
rotation_distance = 40
gear_ratio = 80:16
microsteps = 32

[tmc2209 stepper_z2]
uart_pin = PF2
interpolate = false
run_current = 0.8
sense_resistor = 0.110
stealthchop_threshold = 999999

[stepper_z3]
step_pin = PC13
dir_pin = !PF0
enable_pin = !PF1
rotation_distance = 40
gear_ratio = 80:16
microsteps = 32

[tmc2209 stepper_z3]
uart_pin = PE4
interpolate = false
run_current = 0.8
sense_resistor = 0.110
stealthchop_threshold = 999999

[extruder]
step_pin = orbitoolO2S:PB3
dir_pin = !orbitoolO2S:PB4
enable_pin = !orbitoolO2S:PC14
microsteps = 32
rotation_distance = 4.69
full_steps_per_rotation = 200
nozzle_diameter = 0.400
filament_diameter = 1.750
max_extrude_cross_section = 20
max_extrude_only_distance = 101
max_extrude_only_velocity = 120
pressure_advance = 0.025
pressure_advance_smooth_time = 0.03
heater_pin = orbitoolO2S:PB9
max_power = 0.995
sensor_type = PT1000
sensor_pin = orbitoolO2S:PA1
pullup_resistor = 2200
smooth_time = 0.5
pwm_cycle_time = 0.01
min_extrude_temp = 180
min_temp = -1
max_temp = 270
control = pid
pid_kp = 17.218
pid_ki = 1.208
pid_kd = 61.338

[adc_temperature HOT_P]
temperature1 = 120
voltage1 = 1.91
temperature2 = 240
voltage2 = 3.82

[temperature_sensor Hotend_power]
sensor_pin = orbitoolO2S:PA0
sensor_type = HOT_P

[tmc2240 extruder]
uart_pin = orbitoolO2S:PC13
interpolate = false
run_current = 0.85
rref = 12000
stealthchop_threshold = 0

[heater_bed]
heater_pin = PA3
sensor_type = Generic 3950
sensor_pin = PF3
max_power = 1.0
min_temp = 0
max_temp = 120
control = pid
pid_kp = 64.430
pid_ki = 2.116
pid_kd = 490.476

[cartographer]
mcu = cartographer
x_offset = 0
y_offset = 27
travel_speed = 50
lift_speed = 5
verbose = yes
macro_prefix = CARTO
z_backlash = 0.0091

[cartographer scan]
probe_speed = 5

[cartographer touch]
samples = 3
max_samples = 20
max_noisy_samples = 2
unsafe_max_touch_temperature = 150

[bed_mesh]
zero_reference_position = 150, 150
speed = 300
horizontal_move_z = 3
mesh_min = 30, 30
mesh_max = 270, 270
probe_count = 20, 20
adaptive_margin = 10
mesh_pps = 0,0

[fan]
pin = !orbitoolO2S:PA10
enable_pin = orbitoolO2S:PB14
off_below = 0.2
tachometer_pin = orbitoolO2S:PA14
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
shutdown_speed = 0.0
cycle_time = 0.0001
kick_start_time = 0.2
hardware_pwm = False

[heater_fan Hotend_Fan]
pin = !orbitoolO2S:PB15
tachometer_pin = orbitoolO2S:PB12
tachometer_ppr = 2
tachometer_poll_interval = 0.0005
heater = extruder
cycle_time = 0.0001
heater_temp = 100
fan_speed = 1.0
hardware_pwm = false
shutdown_speed = 0.0
max_power = 0.5

[controller_fan Electronics_Fan]
pin = PD12
max_power = 0.25
kick_start_time = 0.5
idle_timeout = 30
heater = heater_bed
stepper = stepper_x,stepper_y,stepper_z,stepper_z1,stepper_z2,stepper_z3

[fan_generic Exhaust_Fan]
pin = PD13
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[output_pin chamber_light]
pin = PB10
pwm = true
shutdown_value = 0
value = 0
cycle_time = 0.01

[output_pin T0_RUN_LED]
pin = orbitoolO2S:PB13
value = 1
shutdown_value = 0

[idle_timeout]
timeout = 7200

[safe_z_home]
home_xy_position = 150,150
speed = 100
z_hop = 10

[quad_gantry_level]
gantry_corners = 
	-60,-10
	360,370
points = 
	50,25
	50,225
	250,225
	250,25
speed = 150
horizontal_move_z = 5
retries = 5
retry_tolerance = 0.0075
max_adjust = 10

[temperature_sensor Raspberry_Pi]
sensor_type = temperature_host
sensor_path = /sys/class/thermal/thermal_zone0/temp

[temperature_sensor Octopus_Pro]
sensor_type = temperature_mcu
sensor_mcu = mcu

[temperature_sensor chamber]
sensor_type = ATC Semitec 104NT-4-R025H42G
sensor_pin = PF4

[temperature_sensor Hotend_heatsink]
sensor_type = NTC 100K MGB18-104F39050L32
sensor_pin = PF5

[temperature_sensor toolboard]
sensor_type = temperature_mcu
sensor_mcu = orbitoolO2S

[temperature_sensor cartographer]
sensor_type = temperature_mcu
sensor_mcu = cartographer
min_temp = 5
max_temp = 105

[firmware_retraction]
retract_length = 1.2
retract_speed = 120
unretract_extra_length = 0.0
unretract_speed = 120

[adxl345 o2sADXL]
cs_pin = orbitoolO2S:PA4
spi_bus = spi1
axes_map = y, z, x
spi_speed = 5000000

[adxl345 cartoADXL]
cs_pin = cartographer:PA0
spi_bus = spi1

[resonance_tester]
accel_chip = adxl345 o2sADXL
probe_points = 
	150,150,20

[input_shaper]
shaper_freq_x = 82.0
shaper_type_x = 2hump_ei
shaper_freq_y = 40.2
shaper_type_y = mzv

[skew_correction]

[exclude_object]

[axis_twist_compensation]

[gcode_macro G32]
gcode = 
	SAVE_GCODE_STATE NAME=STATE_G32
	G90
	G28
	
	QUAD_GANTRY_LEVEL
	G28
	
	RESTORE_GCODE_STATE NAME=STATE_G32

[gcode_macro PRINT_START]
gcode = 
	
	{% set target_bed = params.BED|int %}
	{% set target_hotend = params.HOTEND|int %}
	{% set target_chamber = params.CHAMBER|default("40")|int %}
	{% set target_chamber_wait = [target_chamber, target_chamber_minimal]|select(">", 0)|min|default(0) %}
	{% set x_wait = printer.toolhead.axis_maximum.x|float / 2 %}
	{% set y_wait = printer.toolhead.axis_maximum.y|float / 2 %}
	
	CLEAR_PAUSE
	
	STATUS_HOMING
	G28
	G90
	
	BED_MESH_CLEAR
	
	
	SET_DISPLAY_TEXT MSG="Set Bed to {target_bed}C"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M190 S{target_bed}
	
	
	{% if params.BED|int > 90 %}
	SET_DISPLAY_TEXT MSG="Heatsoak chamber to {target_chamber_wait}c"
	TEMPERATURE_WAIT SENSOR="temperature_sensor chamber" MINIMUM={target_chamber_wait}
	
	{% else %}
	SET_DISPLAY_TEXT MSG="Soak for 5 min"
	G4 P300000
	{% endif %}
	
	
	SET_DISPLAY_TEXT MSG="Preheat hotend to 150c"
	M109 S150
	
	SET_DISPLAY_TEXT MSG="Cleaning nozzle"
	CLEAN_NOZZLE
	
	SET_DISPLAY_TEXT MSG="Quad Gantry Level"
	STATUS_LEVELING
	QUAD_GANTRY_LEVEL
	
	SET_DISPLAY_TEXT MSG="Cartographer touch home"
	CARTOGRAPHER_TOUCH_HOME
	
	SET_DISPLAY_TEXT MSG="Bed mesh"
	STATUS_MESHING
	BED_MESH_CALIBRATE ADAPTIVE=1
	
	SET_DISPLAY_TEXT MSG="Set hotend to terget temp of {target_hotend}"
	STATUS_HEATING
	G1 X{x_wait} Y{y_wait} Z15 F9000
	M109 S{target_hotend}
	
	SET_DISPLAY_TEXT MSG="Load skew profile"
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural
	
	SET_DIEPLAY_TEXT MSG="Start printing"
	STATUS_PRINTING

[gcode_macro PRINT_END]
gcode = 
	SET_SKEW CLEAR=1
	
	
	{% set th = printer.toolhead %}
	{% set x_safe = th.position.x + 20 * (1 if th.axis_maximum.x - th.position.x > 20 else -1) %}
	{% set y_safe = th.position.y + 20 * (1 if th.axis_maximum.y - th.position.y > 20 else -1) %}
	{% set z_safe = [th.position.z + 2, th.axis_maximum.z]|min %}
	
	SAVE_GCODE_STATE NAME=STATE_PRINT_END
	
	M400
	G92 E0
	G1 E-6.0 F1800
	
	TURN_OFF_HEATERS
	
	G90
	G0 X{x_safe} Y{y_safe} Z{z_safe} F20000
	G0 X{th.axis_maximum.x//2} Y{th.axis_maximum.y - 2} F3600
	
	M107
	
	BED_MESH_CLEAR
	RESTORE_GCODE_STATE NAME=STATE_PRINT_END

[bed_mesh default]
