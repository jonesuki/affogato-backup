	M109 S175
	clean_nozzle
	
	{% if hotendtemp*0.75 <= 150 %}
	M109 S{(hotendtemp*0.75)|round(0,'ceil')|int}
	{% else %}
	M109 S150
	{% endif %}
	
	BED_MESH_CLEAR
	G32
	BED_MESH_CALIBRATE
	G28 Z
	
	G90
	
	
	
	
	Smart_Park
	
	M109 S{hotendtemp}
	
	SKEW_PROFILE LOAD=Fillamentum_Extrafill_ASA_Natural

