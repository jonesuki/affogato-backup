pid_deriv_time = 2.0
target_temp = 45.0
max_speed = 1.0
min_speed = 0.0

[fan_generic Electronics_Fan]
pin = PD12
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[fan_generic Exhaust_Fan]
pin = PD13
max_power = 1.0
shutdown_speed = 0.0
kick_start_time = 5.0

[output_pin chamber_light]
